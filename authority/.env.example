DATABASE_URL=postgres://user:password@localhost:5432/darkroute?sslmode=disable
JWT_SECRET=
RSA_KEY_PATH=./keys/authority.pem
RELAY_API_KEY_SALT=
# Minimum 16 chars. Generate with: openssl rand -base64 24
ALLOWED_RELAY_IPS=
# Comma-separated relay node IPs allowed to call /api/v1/relay/heartbeat.
# Heartbeats from any other source IP are rejected before API key validation.
PORT=3001
ENVIRONMENT=development
